// Entry ruleset pulls in shared rules via loader-level include.
include "shared.adgl"

ruleset "main" {
  version = "1.0"
  evidence main_ev {
    scope: AccessPoint
    anchor a: event(test.main) {
      a.y == 2
    }
    infer Cause(MainSignal) { target: a.target, weight: +10, evidence: [a] }
  }
}
